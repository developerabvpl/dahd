{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.csr.html",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)",
          "/icons/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "masters",
      "urls": [
        "/api/drugs",
        "/api/drugs?**",
        "/api/warehouses",
        "/api/facilities",
        "/api/batches",
        "/api/batches?**"
      ],
      "cacheConfig": {
        "maxSize": 200,
        "maxAge": "7d",
        "timeout": "5s",
        "strategy": "freshness"
      }
    },
    {
      "name": "reads",
      "urls": [
        "/api/dashboard/**",
        "/api/indents",
        "/api/audit/**",
        "/api/coldchain/**",
        "/api/dispense",
        "/api/dispense?**"
      ],
      "cacheConfig": {
        "maxSize": 100,
        "maxAge": "1d",
        "timeout": "5s",
        "strategy": "freshness"
      }
    }
  ]
}
